# Zerodha Kite Connect credentials — OPTIONAL.
# Analysis (universe update, backtest, market phases, trigger check,
# rebalance-from-inputs, swing research) needs NONE of these.
# Only the live features (live cache update, live-holdings rebalance) use them.
#
# Configure via the CLI menu ("Configure Zerodha credentials") — which writes
# a gitignored .env — or copy this file to .env and fill in your own keys.
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
